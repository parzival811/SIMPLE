# Valid program with guaranteed returns on every path
begin
  int result;

  function int classify(int x, bool flag) begin
    if (flag) then
      return x * 2;
    else
      while (x > 0) do
        if (x % 2 == 0) then
          return x / 2;
        fi
        x = x - 1;
      done
      return 0;
    fi
  end

  result = classify(7, false);
end
